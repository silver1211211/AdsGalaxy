DB_HOST=localhost # REQUIRED: MySQL host
DB_PORT=3306 # REQUIRED: MySQL port
DB_USER=dbuser # REQUIRED: MySQL username
DB_PASS=dbpass # REQUIRED: MySQL password
DB_NAME=adsgalaxy_staging # REQUIRED: MySQL database name

ADMIN_SESSION_SECRET=replace_with_at_least_32_random_characters # REQUIRED: signs admin session cookies
ADMIN_SESSION_TTL_SECONDS=28800 # admin session lifetime, default 8 hours
CRON_SECRET=replace_with_long_random_cron_secret # REQUIRED: x-cron-secret header for /api/cron routes
BOT_TOKEN=replace_with_telegram_bot_token # REQUIRED: primary Telegram bot token
TELEGRAM_WEBHOOK_SECRET_TOKEN=replace_with_telegram_webhook_secret_token # REQUIRED: Telegram X-Telegram-Bot-Api-Secret-Token verification
BOT_ADD_USER_SECRET=replace_with_long_random_bot_user_api_secret # REQUIRED: x-bot-add-user-secret for /api/bot/add-user
BOT_WEBHOOK_SECRET=replace_with_long_random_bot_webhook_secret # RECOMMENDED: signs publisher bot webhook URLs; falls back to BOT_ADD_USER_SECRET
BOT_INTEGRATION_ENCRYPTION_KEY=replace_with_at_least_32_random_characters # REQUIRED in production: encrypts per-bot integration secrets at rest
CHANNEL_SCHEDULER_RECOVERY_SLOTS=4 # Number of missed 30-minute channel posting slots eligible for catch-up
CHANNEL_SETTLEMENT_MAX_BATCHES=50 # Maximum channel settlement batches processed per cron run
CRON_MINIAPP_REVENUE_OPTIMIZER_INTERVAL=60 # Minimum optimizer interval in minutes; values below 60 are clamped
CRON_EXTERNAL_NETWORK_REVENUE_SYNC_INTERVAL=60 # Minimum external provider reconciliation interval in minutes; values below 60 are clamped
MINIAPP_STATS_SECRET=replace_with_long_random_internal_stats_secret # REQUIRED if /api/internal/miniapp-stats is used
ENABLE_LOCAL_MINIAPP_DEV=false # local-only browser preview for /dev/miniapp; never enable in production

NEXT_PUBLIC_APP_URL=https://staging.example.com # REQUIRED: public app origin, no trailing slash
NEXT_PUBLIC_SDK_URL=https://staging.example.com # REQUIRED: public SDK origin, no trailing slash
NEXT_PUBLIC_API_BASE_URL=https://staging.example.com # REQUIRED for external SDK/client docs, no trailing slash
NEXT_PUBLIC_ADSGALAXY_APP_URL=https://staging.example.com # legacy alias used by older SDK snippets
DOMAIN=staging.example.com # optional host-only domain for Telegram post links
PHP_VIEWS_API_URL=https://php.adsgalaxy.online/views/api.php # required by update-views cron unless disabled
VIEW_FETCH_BATCH_SIZE=100 # update-views cron batch size, clamped to 1-250
VIEW_FETCH_DELAY_MS=500 # delay between Telegram/public view fetches, clamped to 250-5000ms
TELEGRAM_API_ID=123456 # REQUIRED for private channel MTProto view tracking; from my.telegram.org
TELEGRAM_API_HASH=replace_with_telegram_api_hash # REQUIRED for private channel MTProto view tracking
TELEGRAM_MT_ACCOUNT_1_SESSION=replace_with_tracking_account_1_gramjs_string_session # REQUIRED for private channel MTProto view tracking; keep secret
TELEGRAM_MT_ACCOUNT_2_SESSION=replace_with_tracking_account_2_gramjs_string_session # REQUIRED for private channel MTProto view tracking fallback; keep secret
TELEGRAM_MT_ACCOUNT_1_USERNAME=EarningPandaAdmin # RECOMMENDED: public username shown to private-channel publishers for manual tracking setup
TELEGRAM_MT_ACCOUNT_2_USERNAME=qthfdssv # RECOMMENDED: public username shown to private-channel publishers for manual tracking setup
PRIVATE_INVITE_LINK_ENCRYPTION_KEY=replace_with_at_least_32_random_characters # REQUIRED in production: encrypts private channel moderation invite links

TELEGRAM_BOT_USERNAME=Ads_Galaxy_bot # REQUIRED: bot username without @
NEXT_PUBLIC_BOT_USERNAME=Ads_Galaxy_bot # REQUIRED for client-rendered Telegram links
TELEGRAM_NEWS_CHANNEL=AdsGalaxy_News # REQUIRED: news/referral channel username without @
NEXT_PUBLIC_CHANNEL=AdsGalaxy_News # REQUIRED for client-rendered channel links
NEXT_PUBLIC_CHANNEL_REWARD=0.5 # optional publisher join reward display amount

IMG_API_ENDPOINT=https://img.example.com/api.php # image upload API
OXAPAY_MERCHANT_API_KEY=replace_with_oxapay_key # advertiser deposit provider key
MODE=DEV # DEV or PROD

CRON_POSTS_INTERVAL=10 # cron post interval in minutes
CRON_BROADCAST_WORKERS=3 # bounded broadcast worker count
CRON_BROADCAST_WORKER_MAX=5 # hard cap to protect DB pool
PENDING_DELIVERY_TIMEOUT_MINUTES=10 # mark stuck pending_delivery posts as delivery_failed after this timeout
CHANNEL_POST_LIFETIME_HOURS=24 # fallback lifetime for channel posts before cleanup-expired-posts deletes them after settlement
DELETE_EXPIRED_POSTS_LIMIT=30 # cleanup-expired-posts max Telegram deletions per run, clamped to 1-50
DELETE_EXPIRED_POSTS_DELAY_MS=500 # delay between Telegram delete attempts, clamped to 100-5000ms
CRON_VIEWS_INTERVAL=10 # cron views saving interval in minutes
CRON_SETTLEMENT_INTERVAL=10 # cron settlement interval in minutes

ADSGRAM_BLOCK_ID= # AdsGram publisher block id, normally stored per miniapp network config
ADSGRAM_API_KEY= # Reserved for operations; no verified AdsGram reporting API is wired
MONETAG_ZONE_ID= # Monetag publisher zone id, normally stored per miniapp network config
MONETAG_SDK_URL= # REQUIRED: exact SDK URL from the Monetag-generated script tag (do not use the documentation placeholder)
MONETAG_API_KEY= # Reserved for operations; no verified Monetag reporting API is wired
RICHADS_PUBLISHER_ID= # RichAds publisher ID for Mini App external ad delivery
RICHADS_API_KEY= # Reserved for operations; no verified RichAds reporting API is wired
RICHADS_ZONE_ID= # RichAds widget/app id, normally stored per miniapp network config
ADEXIUM_API_KEY= # REQUIRED for AdExium external revenue reconciliation; Bearer token from publisher account
ADEXIUM_STATS_BASE_URL=https://api.tg-ads.co/api/v1/widget/stats # Optional override for verified AdExium stats API base
GIGAPUB_APP_ID= # GigaPub project/app id, normally stored per miniapp network config
GIGAPUB_API_KEY= # Reserved for operations; no verified GigaPub reporting API is wired
GIGAPUB_PRIMARY_ORIGIN=https://ad.gigapub.tech # optional GigaPub primary script origin
GIGAPUB_BACKUP_ORIGIN=https://ru-ad.gigapub.tech # optional GigaPub backup script origin
CHANNEL_VIEW_FETCH_RUN_RETENTION_DAYS=30 # cleanup-expired-channel-views prunes old fetch-run logs after settlement

TELEGRAM_SUPPORT_API_ID= # MTProto API ID for AdsGalaxy Support account; required only when support sender is enabled
TELEGRAM_SUPPORT_API_HASH= # MTProto API hash for AdsGalaxy Support account; keep secret
TELEGRAM_SUPPORT_SESSION= # GramJS StringSession for AdsGalaxy Support account; keep secret
TELEGRAM_SUPPORT_SENDER_ENABLED=false # must be true before /api/cron/process-support-messages sends real messages
TELEGRAM_SUPPORT_MESSAGE_BATCH_SIZE=5 # conservative support message cron batch size
TELEGRAM_SUPPORT_MESSAGE_BATCH_DELAY_SECONDS=5 # delay between individual support sends
TELEGRAM_SUPPORT_MESSAGE_MAX_RETRIES=3 # retry attempts before permanent failure
TELEGRAM_SUPPORT_MESSAGE_MAX_PER_HOUR=60 # real-send hourly cap; DB setting can override
TELEGRAM_SUPPORT_MESSAGE_MAX_PER_DAY=300 # real-send daily cap; DB setting can override
